{
  "name": "audio-engine",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build:wasm": "asc src/engine/engine.ts --config asconfig.json --target release",
    "watch:wasm": "chokidar 'src/engine/**/*.ts' -c 'npm run build:wasm' --initial",
    "dev": "npm run build:wasm && concurrently --kill-others-on-fail \"npm:watch:wasm\" \"vite\"",
    "build": "npm run build:wasm && tsc && vite build",
    "preview": "vite preview"
  },
  "devDependencies": {
    "assemblyscript": "^0.28.17",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^9.2.1",
    "typescript": "~6.0.2",
    "vite": "^8.0.10"
  }
}
